{
  "all": false,
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/cli.ts",
    "dist/**",
    "vscode-extension/**",
    "scripts/**",
    "examples/**"
  ],
  "reporter": ["text", "lcov", "json-summary"],
  "check-coverage": false,
  "per-file": false,
  "lines": 80,
  "branches": 75,
  "functions": 65,
  "statements": 80
}
