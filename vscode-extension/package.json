{
  "name": "judges-panel",
  "displayName": "Judges Panel",
  "description": "37 judges evaluate AI-generated code for security, cost, and quality — inline diagnostics, quick-fixes, and auto-configured MCP server for Copilot deep review.",
  "version": "3.20.8",
  "publisher": "kevinrabun",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinRabun/judges"
  },
  "homepage": "https://github.com/KevinRabun/judges#readme",
  "bugs": {
    "url": "https://github.com/KevinRabun/judges/issues"
  },
  "galleryBanner": {
    "color": "#1e1b4b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Linters",
    "AI",
    "Chat"
  ],
  "keywords": [
    "code-review",
    "security",
    "mcp",
    "ai-code-review",
    "static-analysis",
    "judges",
    "auto-fix"
  ],
  "activationEvents": [
    "onChatParticipant:judges-panel.judges",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "judges.evaluateFile",
        "title": "Judges: Evaluate Current File",
        "icon": "$(shield)"
      },
      {
        "command": "judges.evaluateWorkspace",
        "title": "Judges: Evaluate Workspace"
      },
      {
        "command": "judges.fixFile",
        "title": "Judges: Auto-Fix Current File",
        "icon": "$(wrench)"
      },
      {
        "command": "judges.clearDiagnostics",
        "title": "Judges: Clear Diagnostics"
      },
      {
        "command": "judges.showPanel",
        "title": "Judges: Show Results Panel"
      },
      {
        "command": "judges.configureMcp",
        "title": "Judges: Configure MCP Server"
      },
      {
        "command": "judges.refineWithAI",
        "title": "Judges: Refine Findings with AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "judges.deepReview",
        "title": "Judges: Deep Review (Layer 1 + Layer 2)",
        "icon": "$(rocket)"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "judges-mcp",
        "label": "Judges Panel"
      }
    ],
    "configuration": {
      "title": "Judges Panel",
      "properties": {
        "judges.evaluateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically evaluate files when saved."
        },
        "judges.preset": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "strict",
            "lenient",
            "security-only",
            "startup",
            "compliance",
            "performance"
          ],
          "description": "Named preset for evaluation configuration."
        },
        "judges.minSeverity": {
          "type": "string",
          "default": "medium",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info"
          ],
          "description": "Minimum severity level to show as diagnostics."
        },
        "judges.enabledJudges": {
          "type": "array",
          "default": [],
          "description": "List of judge IDs to enable (empty = all judges)."
        },
        "judges.debounceMs": {
          "type": "number",
          "default": 1000,
          "description": "Debounce delay in milliseconds for on-save evaluation."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "judges.evaluateFile",
          "group": "navigation",
          "when": "editorLangId =~ /typescript|javascript|python|go|rust|java|csharp|cpp/"
        }
      ],
      "editor/context": [
        {
          "command": "judges.evaluateFile",
          "group": "judges@1"
        },
        {
          "command": "judges.fixFile",
          "group": "judges@2"
        },
        {
          "command": "judges.refineWithAI",
          "group": "judges@3"
        },
        {
          "command": "judges.deepReview",
          "group": "judges@4"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "judges-panel.judges",
        "name": "judges",
        "fullName": "Judges Panel",
        "description": "Evaluate code for security, performance, reliability, and quality using 37 specialized judges",
        "isSticky": false,
        "commands": [
          {
            "name": "review",
            "description": "Review the current file with all 37 judges"
          },
          {
            "name": "deepreview",
            "description": "Combined Layer 1 + Layer 2 deep review (pattern analysis + AI contextual review)"
          },
          {
            "name": "security",
            "description": "Security-focused review of the current file"
          },
          {
            "name": "fix",
            "description": "Auto-fix all fixable findings in the current file"
          },
          {
            "name": "help",
            "description": "Show available commands and usage"
          }
        ],
        "disambiguation": [
          {
            "category": "judges",
            "description": "The user wants to review or evaluate code using judges, judges panel, or judges evaluation",
            "examples": [
              "Review this file with judges",
              "Run a judges panel review",
              "Judges panel evaluation",
              "Evaluate this code with judges",
              "Do a judges review",
              "Run the judges on this file",
              "Judges evaluation of my code",
              "Check this file with judges panel",
              "Deep review this file with judges"
            ]
          },
          {
            "category": "code-review",
            "description": "The user wants to evaluate or review code for security, quality, performance, or compliance issues",
            "examples": [
              "Evaluate this code for security issues",
              "Check this file for vulnerabilities",
              "Review code quality",
              "Run a security review on this file",
              "Check this for compliance issues"
            ]
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "judges_evaluate",
        "toolReferenceName": "judgesEvaluate",
        "displayName": "Judges: Evaluate Code",
        "modelDescription": "Evaluate source code using 37 specialized judges covering security, performance, reliability, cost, compliance, observability, API design, and more. Use this tool when the user asks for a judges panel review, judges evaluation, code quality review, security review, or wants to check code against best practices. Returns findings with severity, description, and suggested fixes.",
        "canBeReferencedInPrompt": true,
        "icon": "$(shield)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Source code to evaluate. If omitted, evaluates the currently open file."
            },
            "language": {
              "type": "string",
              "description": "Programming language (typescript, javascript, python, go, rust, java, csharp, cpp). If omitted, auto-detected from the open file.",
              "enum": ["typescript", "javascript", "python", "go", "rust", "java", "csharp", "cpp"]
            }
          }
        },
        "tags": [
          "judges",
          "code-review",
          "security",
          "evaluate",
          "quality",
          "judges-panel"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild -- --minify",
    "esbuild": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "npm run esbuild",
    "watch": "npm run esbuild -- --watch --sourcemap",
    "package": "npx @vscode/vsce package",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@kevinrabun/judges": "^3.11.2"
  }
}
