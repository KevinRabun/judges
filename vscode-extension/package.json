{
  "name": "judges-panel",
  "displayName": "Judges Panel",
  "description": "45 judges evaluate AI-generated code for security, cost, and quality — inline diagnostics, quick-fixes, and auto-configured MCP server for Copilot deep review.",
  "version": "3.115.4",
  "publisher": "kevinrabun",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinRabun/judges"
  },
  "homepage": "https://github.com/KevinRabun/judges#readme",
  "bugs": {
    "url": "https://github.com/KevinRabun/judges/issues"
  },
  "galleryBanner": {
    "color": "#1e1b4b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Linters",
    "AI",
    "Chat"
  ],
  "keywords": [
    "code-review",
    "security",
    "mcp",
    "ai-code-review",
    "static-analysis",
    "judges",
    "auto-fix"
  ],
  "activationEvents": [
    "onChatParticipant:judges-panel.judges",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:java",
    "onLanguage:csharp",
    "onLanguage:cpp",
    "onLanguage:terraform",
    "onLanguage:bicep",
    "onLanguage:powershell",
    "onLanguage:php",
    "onLanguage:ruby",
    "onLanguage:kotlin",
    "onLanguage:swift"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "judges",
          "title": "Judges Panel",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "judges": [
        {
          "id": "judges.findingsPanel",
          "name": "Findings",
          "icon": "$(checklist)",
          "contextualTitle": "Judges Findings"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "judges.findingsPanel",
        "contents": "Save a file to run 45 judges automatically, or click below.\n[Evaluate Current File](command:judges.evaluateFile)\n[Evaluate Workspace](command:judges.evaluateWorkspace)\n[Open @judges Chat](command:workbench.action.chat.open)"
      }
    ],

    "commands": [
      {
        "command": "judges.evaluateFile",
        "title": "Judges: Evaluate Current File",
        "icon": "$(shield)"
      },
      {
        "command": "judges.evaluateDiff",
        "title": "Judges: Evaluate Changed Lines (Diff-Aware)",
        "icon": "$(git-compare)"
      },
      {
        "command": "judges.evaluateWorkspace",
        "title": "Judges: Evaluate Workspace"
      },
      {
        "command": "judges.fixFile",
        "title": "Judges: Auto-Fix Current File",
        "icon": "$(wrench)"
      },
      {
        "command": "judges.skills.quickPick",
        "title": "Judges: Run Skill (Quick Pick)",
        "category": "Judges",
        "icon": "$(lightbulb)"
      },
      {
        "command": "judges.fixAll",
        "title": "Judges: Accept All Safe Fixes",
        "icon": "$(check-all)"
      },
      {
        "command": "judges.clearDiagnostics",
        "title": "Judges: Clear Diagnostics"
      },
      {
        "command": "judges.showPanel",
        "title": "Judges: Show Results Panel"
      },
      {
        "command": "judges.reviewSession",
        "title": "Judges: Interactive Review Session",
        "icon": "$(checklist)"
      },
      {
        "command": "judges.configureMcp",
        "title": "Judges: Configure MCP Server"
      },
      {
        "command": "judges.addCiWorkflow",
        "title": "Judges: Add CI Workflow",
        "icon": "$(github-action)"
      },
      {
        "command": "judges.refineWithAI",
        "title": "Judges: Refine Findings with AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "judges.deepReview",
        "title": "Judges: Deep Review (Layer 1 + Layer 2)",
        "icon": "$(rocket)"
      },
      {
        "command": "judges.runLlmBenchmark",
        "title": "Judges: Run LLM Benchmark",
        "icon": "$(beaker)"
      },
      {
        "command": "judges.sortBySeverity",
        "title": "Sort by Severity",
        "icon": "$(arrow-down)"
      },
      {
        "command": "judges.sortByFile",
        "title": "Sort by Line",
        "icon": "$(list-ordered)"
      },
      {
        "command": "judges.sortByRule",
        "title": "Sort by Rule",
        "icon": "$(tag)"
      },
      {
        "command": "judges.sortByJudge",
        "title": "Sort by Judge",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "judges.filterAll",
        "title": "Filter: All Severities",
        "icon": "$(filter)"
      },
      {
        "command": "judges.filterCritical",
        "title": "Filter: Critical Only",
        "icon": "$(error)"
      },
      {
        "command": "judges.filterHigh",
        "title": "Filter: High+",
        "icon": "$(warning)"
      },
      {
        "command": "judges.filterMedium",
        "title": "Filter: Medium+",
        "icon": "$(info)"
      },
      {
        "command": "judges.feedbackTp",
        "title": "Judges: Mark as True Positive",
        "icon": "$(thumbsup)"
      },
      {
        "command": "judges.feedbackFp",
        "title": "Judges: Mark as False Positive",
        "icon": "$(thumbsdown)"
      },
      {
        "command": "judges.feedbackWontfix",
        "title": "Judges: Mark as Won't Fix",
        "icon": "$(circle-slash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "judges.evaluateWorkspace",
          "when": "view == judges.findingsPanel",
          "group": "navigation@1"
        },
        {
          "command": "judges.clearDiagnostics",
          "when": "view == judges.findingsPanel",
          "group": "navigation@2"
        },
        {
          "command": "judges.sortBySeverity",
          "when": "view == judges.findingsPanel",
          "group": "1_sort@1"
        },
        {
          "command": "judges.sortByFile",
          "when": "view == judges.findingsPanel",
          "group": "1_sort@2"
        },
        {
          "command": "judges.sortByRule",
          "when": "view == judges.findingsPanel",
          "group": "1_sort@3"
        },
        {
          "command": "judges.sortByJudge",
          "when": "view == judges.findingsPanel",
          "group": "1_sort@4"
        },
        {
          "command": "judges.filterAll",
          "when": "view == judges.findingsPanel",
          "group": "2_filter@1"
        },
        {
          "command": "judges.filterCritical",
          "when": "view == judges.findingsPanel",
          "group": "2_filter@2"
        },
        {
          "command": "judges.filterHigh",
          "when": "view == judges.findingsPanel",
          "group": "2_filter@3"
        },
        {
          "command": "judges.filterMedium",
          "when": "view == judges.findingsPanel",
          "group": "2_filter@4"
        }
      ],
      "editor/title": [
        {
          "command": "judges.evaluateFile",
          "group": "navigation",
          "when": "editorLangId =~ /typescript|javascript|python|go|rust|java|csharp|cpp/"
        }
      ],
      "editor/context": [
        {
          "command": "judges.evaluateFile",
          "group": "judges@1"
        },
        {
          "command": "judges.fixFile",
          "group": "judges@2"
        },
        {
          "command": "judges.refineWithAI",
          "group": "judges@3"
        },
        {
          "command": "judges.deepReview",
          "group": "judges@4"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "judges-mcp",
        "label": "Judges Panel"
      }
    ],
    "configuration": {
      "title": "Judges Panel",
      "properties": {
        "judges.evaluateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically evaluate files when saved."
        },
        "judges.preset": {
          "type": "string",
          "default": "",
          "enum": ["", "strict", "lenient", "security-only", "startup", "compliance", "performance"],
          "enumDescriptions": [
            "All judges, default severity threshold",
            "All judges, show all severities",
            "All judges, relaxed — critical + high only",
            "Security, auth, data, compliance judges only",
            "Lightweight — security + performance + error handling",
            "Compliance, data sovereignty, ethics judges",
            "Performance, caching, scalability judges"
          ],
          "description": "Named preset or comma-separated preset composition (e.g., 'security-only,performance'). Available: strict, lenient, security-only, startup, compliance, performance."
        },
        "judges.minSeverity": {
          "type": "string",
          "default": "high",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info"
          ],
          "description": "Minimum severity level to show as diagnostics."
        },
        "judges.enabledJudges": {
          "type": "array",
          "default": [],
          "description": "List of judge IDs to enable (empty = all judges)."
        },
        "judges.debounceMs": {
          "type": "number",
          "default": 1000,
          "description": "Debounce delay in milliseconds for on-save evaluation."
        },
        "judges.evaluateOnChange": {
          "type": "boolean",
          "default": false,
          "description": "Evaluate files in real-time as you type (uses a longer debounce). May increase CPU usage."
        },
        "judges.changeDebounceMs": {
          "type": "number",
          "default": 2000,
          "description": "Debounce delay in milliseconds for on-change evaluation."
        },
        "judges.exclude": {
          "type": "array",
          "default": [],
          "items": { "type": "string" },
          "description": "Glob patterns to exclude files from workspace evaluation (e.g., '**/test/**', '*.spec.ts')."
        },
        "judges.include": {
          "type": "array",
          "default": [],
          "items": { "type": "string" },
          "description": "Glob patterns to include only matching files in workspace evaluation."
        },        "judges.llmBenchmark.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable LLM benchmark runner (disabled by default to protect extension host memory). Env override: JUDGES_LLM_BENCHMARK_ENABLED=true"
        },
        "judges.llmBenchmark.sampleSize": {
          "type": "number",
          "default": 32,
          "minimum": 1,
          "description": "Number of stratified benchmark cases to run for LLM benchmark. Set env JUDGES_LLM_BENCHMARK_SAMPLE_SIZE to override at runtime."
        },
        "judges.llmBenchmark.maxOutputTokens": {
          "type": "number",
          "default": 1024,
          "minimum": 128,
          "description": "Maximum output tokens requested per LLM call. Env override: JUDGES_LLM_BENCHMARK_MAX_OUTPUT_TOKENS. Lowering reduces memory/latency."
        },
        "judges.llmBenchmark.concurrency": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 2,
          "description": "Parallel LLM requests. 1 strongly recommended to avoid stream leaks. Env override: JUDGES_LLM_BENCHMARK_CONCURRENCY."
        },
        "judges.llmBenchmark.interRequestDelayMs": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "Delay between sequential LLM requests to avoid throttling. Env override: JUDGES_LLM_BENCHMARK_INTER_DELAY_MS."
        },
        "judges.llmBenchmark.maxRetries": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Retries for empty/error responses. Env override: JUDGES_LLM_BENCHMARK_MAX_RETRIES."
        },
        "judges.llmBenchmark.retryBaseDelayMs": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "Base delay for exponential backoff (ms). Env override: JUDGES_LLM_BENCHMARK_RETRY_BASE_MS."
        },
        "judges.llmBenchmark.maxConsecutiveEmpty": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Abort if this many consecutive LLM calls return empty. Env override: JUDGES_LLM_BENCHMARK_MAX_EMPTY."
        },
        "judges.llmBenchmark.responseSnapshotChars": {
          "type": "number",
          "default": 1000,
          "minimum": 128,
          "description": "Truncate stored raw LLM responses to this many characters to reduce memory. Env override: JUDGES_LLM_BENCHMARK_RESPONSE_SNAPSHOT_CHARS."
        },
        "judges.llmBenchmark.maxHeapMb": {
          "type": "number",
          "default": 1024,
          "minimum": 256,
          "description": "Soft heap guard (MB). Benchmark aborts if heapUsed exceeds this. Env override: JUDGES_LLM_BENCHMARK_MAX_HEAP_MB."
        },
        "judges.llmBenchmark.logMemoryEvery": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Log memory stats every N LLM calls. Env override: JUDGES_LLM_BENCHMARK_LOG_MEMORY_EVERY."
        },        "judges.maxFiles": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of files to evaluate in workspace mode."
        },
        "judges.confidenceTier": {
          "type": "string",
          "default": "important",
          "enum": [
            "essential",
            "important",
            "supplementary"
          ],
          "enumDescriptions": [
            "Show only high-confidence findings (≥ 0.8)",
            "Show high and medium-confidence findings (≥ 0.6)",
            "Show all findings including low-confidence"
          ],
          "description": "Minimum confidence tier for displayed findings."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "judges-panel.judges",
        "name": "judges",
        "fullName": "Judges Panel",
        "description": "Evaluate code for security, performance, reliability, and quality using 45 specialized judges",
        "isSticky": false,
        "commands": [
          {
            "name": "review",
            "description": "Deep review — Layer 1 (pattern analysis) + Layer 2 (AI contextual review)"
          },
          {
            "name": "deepreview",
            "description": "Same as /review — Layer 1 + Layer 2 deep review"
          },
          {
            "name": "shallowreview",
            "description": "Pattern analysis only (Layer 1 — no AI deep review)"
          },
          {
            "name": "security",
            "description": "Security-focused pattern review of the current file"
          },
          {
            "name": "fix",
            "description": "Auto-fix all fixable findings in the current file"
          },
          {
            "name": "benchmark",
            "description": "Run LLM benchmark — evaluate all judges against test cases using the current model"
          },
          {
            "name": "help",
            "description": "Show available commands and usage"
          }
        ],
        "disambiguation": [
          {
            "category": "judges",
            "description": "The user wants to review or evaluate code using judges, judges panel, or judges evaluation",
            "examples": [
              "Review this file with judges",
              "Run a judges panel review",
              "Judges panel evaluation",
              "Evaluate this code with judges",
              "Do a judges review",
              "Run the judges on this file",
              "Judges evaluation of my code",
              "Check this file with judges panel",
              "Deep review this file with judges"
            ]
          },
          {
            "category": "code-review",
            "description": "The user wants to evaluate or review code for security, quality, performance, or compliance issues",
            "examples": [
              "Evaluate this code for security issues",
              "Check this file for vulnerabilities",
              "Review code quality",
              "Run a security review on this file",
              "Check this for compliance issues"
            ]
          }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "judges_evaluate",
        "toolReferenceName": "judgesEvaluate",
        "displayName": "Judges: Evaluate Code",
        "modelDescription": "Evaluate source code using 45 specialized judges covering security, performance, reliability, cost, compliance, observability, API design, and more. Use this tool when the user asks for a judges panel review, judges evaluation, code quality review, security review, or wants to check code against best practices. Returns findings with severity, description, and suggested fixes.",
        "canBeReferencedInPrompt": true,
        "icon": "$(shield)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Source code to evaluate. If omitted, evaluates the currently open file."
            },
            "language": {
              "type": "string",
              "description": "Programming language (typescript, javascript, python, go, rust, java, csharp, cpp). If omitted, auto-detected from the open file.",
              "enum": [
                "typescript",
                "javascript",
                "python",
                "go",
                "rust",
                "java",
                "csharp",
                "cpp"
              ]
            }
          }
        },
        "tags": [
          "judges",
          "code-review",
          "security",
          "evaluate",
          "quality",
          "judges-panel"
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild -- --minify",
    "esbuild": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "npm run esbuild",
    "watch": "npm run esbuild -- --watch --sourcemap",
    "package": "npx @vscode/vsce package",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.109.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@kevinrabun/judges": "^3.115.3"
  },
  "overrides": {
    "yauzl": "^3.2.1"
  }
}
