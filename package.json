{
  "name": "@kevinrabun/judges",
  "version": "3.115.0",
  "description": "45 specialized judges that evaluate AI-generated code for security, cost, and quality.",
  "mcpName": "io.github.KevinRabun/judges",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "judges": "packages/judges-cli/bin/judges.js"
  },
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./api": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sarif": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./junit": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./codeclimate": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./badge": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./diagnostics": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./plugins": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./fingerprint": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./comparison": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    }
  },
  "files": [
    "dist/api.js",
    "dist/api.d.ts",
    "dist/auto-tune.js",
    "dist/auto-tune.d.ts",
    "dist/cache.js",
    "dist/cache.d.ts",
    "dist/calibration.js",
    "dist/calibration.d.ts",
    "dist/comparison.js",
    "dist/comparison.d.ts",
    "dist/config.js",
    "dist/config.d.ts",
    "dist/data-adapter.js",
    "dist/data-adapter.d.ts",
    "dist/dedup.js",
    "dist/dedup.d.ts",
    "dist/disk-cache.js",
    "dist/disk-cache.d.ts",
    "dist/errors.js",
    "dist/errors.d.ts",
    "dist/finding-lifecycle.js",
    "dist/finding-lifecycle.d.ts",
    "dist/fingerprint.js",
    "dist/fingerprint.d.ts",
    "dist/fix-history.js",
    "dist/fix-history.d.ts",
    "agents/**/*.judge.md",
    "skills/**/*.skill.md",
    "docs/skills.md",
    "scripts/generate-agents-from-judges.ts",
    "scripts/validate-agents.ts",
    "scripts/generate-skills-docs.ts",
    "src/agent-loader.ts",
    "src/skill-loader.ts",
    "dist/github-app.js",
    "dist/github-app.d.ts",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/judge-registry.js",
    "dist/judge-registry.d.ts",
    "dist/language-patterns.js",
    "dist/language-patterns.d.ts",
    "dist/parallel.js",
    "dist/parallel.d.ts",
    "dist/plugins.js",
    "dist/plugins.d.ts",
    "dist/presets.js",
    "dist/presets.d.ts",
    "dist/scoring.js",
    "dist/scoring.d.ts",
    "dist/security-ids.js",
    "dist/security-ids.d.ts",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/ast/**/*.js",
    "dist/ast/**/*.d.ts",
    "dist/evaluators/**/*.js",
    "dist/evaluators/**/*.d.ts",
    "dist/formatters/**/*.js",
    "dist/formatters/**/*.d.ts",
    "dist/judges/**/*.js",
    "dist/judges/**/*.d.ts",
    "dist/patches/**/*.js",
    "dist/patches/**/*.d.ts",
    "dist/reports/**/*.js",
    "dist/reports/**/*.d.ts",
    "dist/tools/**/*.js",
    "dist/tools/**/*.d.ts",
    "dist/commands/auto-detect.js",
    "dist/commands/auto-detect.d.ts",
    "dist/commands/benchmark*.js",
    "dist/commands/benchmark*.d.ts",
    "dist/commands/config-share.js",
    "dist/commands/config-share.d.ts",
    "dist/commands/coverage.js",
    "dist/commands/coverage.d.ts",
    "dist/commands/doctor.js",
    "dist/commands/doctor.d.ts",
    "dist/commands/feedback.js",
    "dist/commands/feedback.d.ts",
    "dist/commands/fix.js",
    "dist/commands/fix.d.ts",
    "dist/commands/language-packs.js",
    "dist/commands/language-packs.d.ts",
    "dist/commands/llm-benchmark.js",
    "dist/commands/llm-benchmark.d.ts",
    "dist/commands/review.js",
    "dist/commands/review.d.ts",
    "dist/commands/rule-metrics.js",
    "dist/commands/rule-metrics.d.ts",
    "dist/commands/rule.js",
    "dist/commands/rule.d.ts",
    "dist/commands/smart-output.js",
    "dist/commands/smart-output.d.ts",
    "dist/commands/snapshot.js",
    "dist/commands/snapshot.d.ts",
    "server.json",
    "judgesrc.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:js && npm run build:cli-package",
    "build:types": "tsc --emitDeclarationOnly --declarationMap false --sourceMap false",
    "build:js": "tsc -p tsconfig.build-js.json",
    "build:cli-package": "node scripts/prepare-cli-package.mjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "npx tsx --test \"tests/**/*.test.ts\"",
    "test:coverage": "node scripts/run-tests-with-coverage.mjs",
    "self-eval": "npx tsx scripts/self-eval.ts",
    "check": "tsc --noEmit && eslint src/ tests/ && npx tsx scripts/self-eval.ts && npm run validate:agents && npm run check:agents",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "demo": "npx tsx examples/demo.ts",
    "report:public-repo": "npx tsx scripts/generate-public-repo-report.ts",
    "report:quickstart": "npx tsx scripts/generate-public-repo-report.ts --quickStart",
    "automation:daily-popular": "npx tsx scripts/daily-popular-repo-autofix.ts",
    "sync-docs": "npx tsx scripts/sync-docs.ts",
    "generate:agents": "npx tsx scripts/generate-agents-from-judges.ts",
    "generate:agents:force": "npx tsx scripts/generate-agents-from-judges.ts --force",
    "validate:agents": "npx tsx scripts/validate-agents.ts",
    "docs:skills": "npx tsx scripts/generate-skills-docs.ts",
    "check:agents": "npx tsx scripts/check-agents.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "code-review",
    "security",
    "tribunal",
    "ai-code-review",
    "code-quality",
    "static-analysis",
    "dual-layer-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinRabun/judges.git"
  },
  "homepage": "https://github.com/KevinRabun/judges#readme",
  "bugs": {
    "url": "https://github.com/KevinRabun/judges/issues"
  },
  "author": "kevinrabun",
  "license": "MIT",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "typescript": "^5.9.3",
    "web-tree-sitter": "^0.26.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4"
  },
  "overrides": {
    "hono": ">=4.12.7"
  }
}
