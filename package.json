{
  "name": "@kevinrabun/judges",
  "version": "3.59.0",
  "description": "45 specialized judges that evaluate AI-generated code for security, cost, and quality.",
  "mcpName": "io.github.KevinRabun/judges",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./api": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sarif": {
      "import": "./dist/formatters/sarif.js",
      "types": "./dist/formatters/sarif.d.ts"
    },
    "./junit": {
      "import": "./dist/formatters/junit.js",
      "types": "./dist/formatters/junit.d.ts"
    },
    "./codeclimate": {
      "import": "./dist/formatters/codeclimate.js",
      "types": "./dist/formatters/codeclimate.d.ts"
    },
    "./badge": {
      "import": "./dist/formatters/badge.js",
      "types": "./dist/formatters/badge.d.ts"
    },
    "./diagnostics": {
      "import": "./dist/formatters/diagnostics.js",
      "types": "./dist/formatters/diagnostics.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins.js",
      "types": "./dist/plugins.d.ts"
    },
    "./fingerprint": {
      "import": "./dist/fingerprint.js",
      "types": "./dist/fingerprint.d.ts"
    },
    "./comparison": {
      "import": "./dist/comparison.js",
      "types": "./dist/comparison.d.ts"
    }
  },
  "bin": {
    "judges": "dist/index.js"
  },
  "files": [
    "dist",
    "grammars",
    "server.json",
    "judgesrc.schema.json",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "npx tsx --test tests/judges.test.ts",
    "test:coverage": "npx c8 --reporter=text --reporter=lcov npx tsx --test tests/judges.test.ts",
    "self-eval": "npx tsx scripts/self-eval.ts",
    "check": "tsc --noEmit && eslint src/ tests/ && npx tsx scripts/self-eval.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "demo": "npx tsx examples/demo.ts",
    "report:public-repo": "npx tsx scripts/generate-public-repo-report.ts",
    "report:quickstart": "npx tsx scripts/generate-public-repo-report.ts --quickStart",
    "automation:daily-popular": "npx tsx scripts/daily-popular-repo-autofix.ts",
    "benchmark:llm": "npx tsx scripts/run-llm-benchmark.ts",
    "sync-docs": "npx tsx scripts/sync-docs.ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "code-review",
    "security",
    "tribunal",
    "ai-code-review",
    "code-quality",
    "static-analysis",
    "dual-layer-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KevinRabun/judges.git"
  },
  "homepage": "https://github.com/KevinRabun/judges#readme",
  "bugs": {
    "url": "https://github.com/KevinRabun/judges/issues"
  },
  "author": "kevinrabun",
  "license": "MIT",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "typescript": "^5.9.3",
    "web-tree-sitter": "^0.26.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4"
  },
  "overrides": {
    "hono": ">=4.12.7"
  }
}
